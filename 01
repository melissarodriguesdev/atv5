<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Cadastro de Aluno</title>
    <link rel="stylesheet" href="style.css">
</head>

<style>
    .container{
    width: 300px;
    height: 300px;
    border: 2px solid black;
    padding: 20px;
    margin: auto;
}


    input {
        width: 100%;
        margin-bottom: 10px;
        }

</style>
<body>
    <div class="container">
    <h2>Cadastro de aluno</h2>

    <form>
    <label>Nome</label>
    <input type="text" required>
    <br>

    <label>Email</label>
    <input type="email" required>
    <br>

    <label>Telefone</label>
    <input type="tel" required>
    <br>

    <label>Curso</label>
    <select>
    <option>HTML</option>
    <option style="background-color: rgb(36, 149, 111);">CSS</option>
    <option style="color: rgb(80, 100, 1);">JAVA</option>
    <option style="color: rgb(240, 36, 97);">PHP</option>
    <br>

    </select>

    <button type="submit", style="background-color: aquamarine;">Cadastrar</button>

    </form>
    </div>
    
</body>
</html>
