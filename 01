<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Cadastro de Aluno</title>
    <link rel="stylesheet" href="style.css">
</head>

<style>
        body {
            background-color: #ffd0f7;
            font-family: Arial;
            display: flex;
            justify-content: center; 
            align-items: center; 
            height: 100vh;
        }

        .container {
            width: 300px;
            height: 300px;
            background-color: rgb(255, 179, 223);
            padding: 20px;
            border-radius: 10px;
            margin: 0 auto;

        }


        input {
            width: 100%;
            margin-bottom: 10px;
        }

</style>
<body>
    <div class="container">
    <h2>Cadastro de aluno</h2>

    <form>
    <label>Nome</label>
    <input type="text" required>
    <br>

    <label>Email</label>
    <input type="email" required>
    <br>

    <label>Telefone</label>
    <input type="tel" required>
    <br>

    <label>Curso</label>
    <select>
    <option>HTML</option>
    <option style="background-color: rgb(36, 149, 111);">CSS</option>
    <option style="color: rgb(253, 154, 24);">JAVA</option>
    <option style="color: rgb(240, 36, 97);">PHP</option>
    <br>

    </select>

    <button type="submit", style="background-color: aquamarine;">Cadastrar</button>

    </form>
    </div>
    
</body>
</html>
