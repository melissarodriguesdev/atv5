<!DOCTYPE html>
<html>
<head>
    <style>
        body {
            background-color: #806d6d;
            font-family: Arial;
        }

        form {
            background-color: white;
            padding: 20px;
            width: 300px;
        }

        label {
            font-weight: bold;
            color: blue;
        }

        input {
            width: 100%;
            margin-bottom: 10px;
        }

        #nome {
            border: 2px solid rgb(96, 8, 16);
        }

        #lname {
            border: 2px solid rgb(10, 63, 10);
        }
    </style>
</head>
<body>

<form>
    <label for="nome">Nome: </label>
    <input type="text" id="nome" name="nome">

    <label for="lname">Sobrenome:</label>
    <input type="text" id="lname" name="lname">
</form>

</body>
</html>
